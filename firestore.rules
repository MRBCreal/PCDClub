rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Global super admin
    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'realmrb@gmail.com' ||
        request.auth.token.email == 'pcdproyecto@gmail.com' ||
        exists(/databases/$(database)/documents/superadmins/$(request.auth.uid))
      );
    }

    // Helper: Check if user is the document owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper: Check if user has a specific role in a club
    function hasClubRole(clubId, role) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid)).data.role == role;
    }

    // Helper: Check if user is club admin or owner
    function isClubAdmin(clubId) {
      return hasClubRole(clubId, 'admin') || hasClubRole(clubId, 'owner');
    }

    // Helper: can manage membership roles in a club
    function canAssignClubRole(clubId, newRole) {
      return (isSuperAdmin() && (newRole == 'owner' || newRole == 'admin' || newRole == 'member' || newRole == 'parent')) ||
        (isClubAdmin(clubId) && (newRole == 'member' || newRole == 'parent'));
    }

    // Helper: Check if user is a member of the club
    function isClubMember(clubId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid));
    }

    // Helper: Check if user is club manager (Admin, Owner or the UID matches ownerId of the club)
    function isClubManager(clubId) {
      return isSuperAdmin() ||
        isClubAdmin(clubId) ||
        (isAuthenticated() && get(/databases/$(database)/documents/clubs/$(clubId)).data.ownerId == request.auth.uid);
    }

    // Helper: Check if user WILL BE club manager after the current batch/transaction
    function isClubManagerAfter(clubId) {
      return isSuperAdmin() ||
        (isAuthenticated() && getAfter(/databases/$(database)/documents/clubs/$(clubId)).data.ownerId == request.auth.uid);
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) || isSuperAdmin();
      allow update: if isOwner(userId) || isSuperAdmin();
      allow delete: if false;
    }

    // Superadmins collection
    match /superadmins/{adminId} {
      allow read: if isOwner(adminId) || isSuperAdmin();
      allow create, update, delete: if false;
    }

    // Clubs collection
    match /clubs/{clubId} {
      allow read: if isAuthenticated();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || isClubAdmin(clubId);
      allow delete: if isSuperAdmin() || hasClubRole(clubId, 'owner');

      // Club members subcollection
      match /members/{memberId} {
        allow read: if isClubManager(clubId) || isOwner(memberId);

        // Create / update allowed, but constrain role assignment to prevent escalation
        allow create: if (isClubManager(clubId) || isClubManagerAfter(clubId)) &&
          (!('role' in request.resource.data) || canAssignClubRole(clubId, request.resource.data.role));

        allow update: if (isClubManager(clubId) || isOwner(memberId)) &&
          (!('role' in request.resource.data) || canAssignClubRole(clubId, request.resource.data.role));

        allow delete: if isClubManager(clubId);
      }

      // Club payments subcollection
      match /payments/{paymentId} {
        allow read: if isClubManager(clubId) || isOwner(resource.data.memberId);
        allow create: if isClubManager(clubId);
        allow update: if isClubManager(clubId);
        allow delete: if false;
      }

      // Club invoices subcollection
      match /invoices/{invoiceId} {
        allow read: if isClubManager(clubId) || isOwner(resource.data.memberId);
        allow create: if isClubManager(clubId);
        allow update: if isClubManager(clubId);
        allow delete: if false;
      }

      // Club events subcollection
      match /events/{eventId} {
        allow read: if isClubManager(clubId) || isClubMember(clubId);
        allow create: if isClubManager(clubId);
        allow update: if isClubManager(clubId);
        allow delete: if isClubManager(clubId);
      }

      // Club attendance subcollection
      match /attendance/{attendanceId} {
        allow read: if isClubManager(clubId) || isOwner(resource.data.memberId);
        allow create: if isClubManager(clubId);
        allow update: if isClubManager(clubId);
        allow delete: if isClubManager(clubId);
      }

      // Club documents subcollection
      match /documents/{documentId} {
        allow read: if isClubManager(clubId) || isClubMember(clubId);
        allow create: if isClubManager(clubId);
        allow update: if isClubManager(clubId);
        allow delete: if isClubManager(clubId);
      }

      // Club settings subcollection
      match /settings/{settingId} {
        allow read: if isClubManager(clubId);
        allow write: if isClubManager(clubId);
      }

      // Club courts subcollection
      match /courts/{courtId} {
        allow read: if isClubManager(clubId) || isClubMember(clubId);
        allow create, update, delete: if isClubManager(clubId);
      }

      // Club bookings subcollection
      match /bookings/{bookingId} {
        allow read: if isClubManager(clubId) || isClubMember(clubId);
        allow create: if isClubManager(clubId) || isClubMember(clubId);
        allow update: if isClubManager(clubId) || (isClubMember(clubId) && resource.data.memberId == request.auth.uid);
        allow delete: if isClubManager(clubId);
      }

      // Club matches subcollection
      match /matches/{matchId} {
        allow read: if isClubManager(clubId) || isClubMember(clubId);
        allow create, update, delete: if isClubManager(clubId);
      }

      // Club divisions subcollection
      match /divisions/{divisionId} {
        allow read: if isClubManager(clubId) || isClubMember(clubId);
        allow create, update, delete: if isClubManager(clubId);
      }
    }

    // Payment transactions (global for webhook processing)
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if false; // Only server-side
      allow update: if false; // Only server-side
      allow delete: if false;
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if false; // Only server-side
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Support for collectionGroup(members) queries
    match /{path=**}/members/{memberId} {
      allow read: if isAuthenticated();
    }
  }
}
